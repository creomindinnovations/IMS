rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return exists(userPath());
    }

    function userDoc() {
      return get(userPath());
    }

    function getRole() {
      return userDoc().data.role;
    }

    function isAdmin() {
      return isAuth() && userExists() && getRole() == 'admin';
    }

    function isTeamLead() {
      return isAuth() && userExists() && getRole() == 'teamlead';
    }

    function isInternOnTeam(teamLeadId) {
      return isAuth()
        && userExists()
        && userDoc().data.role == 'intern'
        && userDoc().data.teamLeadId == teamLeadId;
    }

    match /users/{uid} {
      allow get: if isAuth() && request.auth.uid == uid;
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /attendance/{docId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth()
        && resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /tutorials/{tutId} {
      allow read: if isAuth()
        && (resource.data.isPublished == true || isAdmin() || isTeamLead());
      allow create: if isAuth() && (isAdmin() || isTeamLead());
      allow update, delete: if isAdmin();
    }

    match /progress/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin() || isTeamLead());
      allow create, update: if isAuth() && request.auth.uid == uid;
    }

    match /leave_requests/{leaveId} {
      allow read: if isAuth()
        && (resource.data.uid == request.auth.uid || isAdmin() || isTeamLead());
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    match /offer_letters/{letterId} {
      allow read: if isAuth()
        && (resource.data.internUid == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /certificates/{certId} {
      allow read: if isAuth()
        && (resource.data.internUid == request.auth.uid
            || isAdmin()
            || (isTeamLead() && resource.data.status == 'approved'));
      allow write: if isAdmin();
    }

    match /announcements/{id} {
      allow read: if isAuth();
      allow write: if isAdmin() || isTeamLead();
    }

    match /settings/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
